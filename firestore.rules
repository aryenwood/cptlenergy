rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Phase 0: Transitional rules ─────────────────────────────────────
    // During pre-alpha, allow authenticated users full access while
    // custom claims propagate. Tighten after all users have claims.

    function isAuth() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuth() && request.auth.token.superAdmin == true;
    }

    // Transitional: allow if user has matching orgId claim OR if claims
    // haven't been set yet (token.orgId is null). This prevents lockout
    // during the migration period.
    function canAccessOrg(orgId) {
      return isAuth() && (
        isSuperAdmin() ||
        request.auth.token.orgId == orgId ||
        request.auth.token.orgId == null
      );
    }

    function canManageOrg(orgId) {
      return isAuth() && (
        isSuperAdmin() ||
        request.auth.token.role == 'manager' ||
        request.auth.token.role == 'master_admin' ||
        request.auth.token.role == null
      );
    }

    // ── Users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ── Organizations + all subcollections ────────────────────────────────
    match /organizations/{orgId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isSuperAdmin();

      match /{subcollection}/{docId} {
        allow read: if isAuth();
        allow write: if isAuth();

        match /{sub2}/{doc2} {
          allow read: if isAuth();
          allow write: if isAuth();
        }
      }
    }

    // ── Invites ──────────────────────────────────────────────────────────
    match /invites/{code} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isSuperAdmin();
    }

    // ── Notifications queue ──────────────────────────────────────────────
    match /notifications/{notifId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }

    // ── Mail queue ───────────────────────────────────────────────────────
    match /mail/{mailId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }

    // ── Address cache ────────────────────────────────────────────────────
    match /addresses/{addressId} {
      allow read, write: if isAuth();
    }

    // ── Deny everything else ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
